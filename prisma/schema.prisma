datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Employee {
  id             String         @id // Matches Supabase Auth ID
  name           String
  email          String         @unique
  role           String         // "Admin" | "Manager" | "Employee"
  department     String
  avatarInitials String
  status         String         // "Active" | "Inactive"
  currentPunchIn String?        // Optional punch record compatibility
  currentPunchInPhoto String?
  currentPunchInLat   Float?
  currentPunchInLng   Float?
  companyName    String?        // Company Name for Admins/Managers
  companyAddress String?        // Company Address for Admins/Managers
  employeeCount  String?        // Employee Count range
  wid            Int?           // Workspace ID
  employeeCode          String?        // Unique Employee Code
  phoneNumber           String?        // Phone Number
  joiningDate           String?        // Date of Joining
  designation           String?        // Job Title
  employmentType        String?        // e.g. Full-time, Part-time, Contract, Intern
  reportingManager      String?        // Name of Reporting Manager
  reportingHR           String?        // Name of Reporting HR
  workLocation          String?        // e.g. Remote, On-site, Hybrid
  branch                String?        // Assigned branch/office name
  rosterShift           String?        // Assigned shift roster name
  personalEmail         String?        // Personal Email Address
  dateOfBirth           String?        // Date of Birth (YYYY-MM-DD)
  emergencyContactName  String?        // Emergency Contact Name
  emergencyContactPhone String?        // Emergency Contact Phone
  bloodGroup            String?        // e.g. A+, B-, O+
  createdAt             DateTime       @default(now())
  claims                ExpenseClaim[]
  announcements         Announcement[]
  supportTickets        SupportTicket[]
  companyExpenses       CompanyExpense[]
}

model ExpenseClaim {
  id             String          @id @default(cuid())
  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title          String
  category       String          // "Travel" | "Meals" | "Software" | "Office Supplies" | "Mileage" | "Other"
  amount         Float
  currency       String          @default("USD")
  date           String          // Date string "YYYY-MM-DD"
  status         String          // "Pending" | "Approved" | "Rejected" | "NeedsInfo"
  reason         String          @default("")
  receiptUrl     String?         // S3 URL of the receipt photo
  isMileage      Boolean         @default(false)
  mileageRate    Float?          // Rate per Km
  distanceKm     Float?          // Distance travelled
  taxPercent     Float           @default(0)
  taxAmount      Float           @default(0)
  projectId      String?
  project        WorkspaceProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  approvedBy     String?         // Employee ID of the approver
  wid            Int?            // Workspace ID
  appliedAt      DateTime        @default(now())
  comments       ExpenseComment[]
  companyExpense CompanyExpense?  // Auto-created when claim is approved
}

model ExpenseComment {
  id         String       @id @default(cuid())
  claimId    String
  claim      ExpenseClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  employeeId String
  authorName String
  content    String
  createdAt  DateTime     @default(now())
}

model WorkspaceProject {
  id          String         @id @default(cuid())
  name        String
  clientName  String?
  description String?
  wid         Int            @default(1)
  createdAt   DateTime       @default(now())
  claims      ExpenseClaim[]

  @@unique([name, wid])
}

model Workspace {
  id            Int            @id @default(autoincrement())
  name          String?
  plan          String         @default("free") // "free" | "pro"
  planExpiresAt DateTime?
  trialEndsAt   DateTime?      // 14-day Pro trial for new workspaces
  maxUsers      Int            @default(5)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  transactions  Transaction[]
  settingsJson  String         @default("{\"branches\":[{\"id\":\"branch-hq\",\"name\":\"Main HQ\",\"address\":\"123 Corporate Tower, New Delhi, India\",\"pincode\":\"110001\",\"city\":\"New Delhi\",\"state\":\"Delhi\",\"latitude\":28.6139,\"longitude\":77.2090,\"allowWFH\":true}]}")
}

model Subscription {
  id              String        @id @default(cuid())
  workspaceId     Int
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employeeId      String?
  status          String        // "PENDING" | "ACTIVE" | "CANCELLED"
  plan            String        // "pro"
  seatsCount      Int           @default(1)
  billingCycle    String        // "monthly" | "yearly"
  amountPaisa     Int
  currency        String        @default("INR")
  razorpayOrderId String?
  startsAt        DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  transactions    Transaction[]

  @@index([workspaceId])
  @@index([razorpayOrderId])
}

model Transaction {
  id                String        @id @default(cuid())
  workspaceId       Int
  workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  status            String        // "CREATED" | "SUCCESS" | "FAILED"
  amountPaisa       Int
  currency          String        @default("INR")
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  description       String?
  createdAt         DateTime      @default(now())

  @@index([workspaceId])
  @@index([subscriptionId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  pinned      Boolean   @default(false)
  archived    Boolean   @default(false)
  wid         Int
  authorId    String
  author      Employee  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorName  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SupportTicket {
  id          String   @id @default(cuid())
  subject     String
  description String
  priority    String   // "Low" | "Medium" | "High"
  category    String   // "IT Support" | "HR Support" | "Finance & Payouts" | "General Inquiry"
  status      String   @default("Open") // "Open" | "In Progress" | "Resolved"
  resolution  String?  // Optional resolution notes
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  wid         Int      @default(1)
  createdAt   DateTime @default(now())
}

model CompanyExpense {
  id            String        @id @default(cuid())
  title         String
  amount        Float
  currency      String        @default("USD")
  category      String        // "Rent & Utilities" | "SaaS & Software" | "Marketing & Ads" | "Office Operations" | "Salaries & Payroll" | "Other"
  date          String        // "YYYY-MM-DD"
  paymentMethod String        // "Cash" | "Company Card" | "Bank Transfer" | "Cheque" | "Other"
  paymentStatus String        // "Paid" | "Unpaid" | "Scheduled"
  receiptUrl    String?       // Comma-separated list of attachments (up to 3)
  vendor        String?
  notes         String?       @default("")
  wid           Int           @default(1)
  loggedById    String
  loggedBy      Employee      @relation(fields: [loggedById], references: [id], onDelete: Cascade)
  claimId       String?       @unique // Links to an ExpenseClaim if auto-generated from an approved claim
  claim         ExpenseClaim? @relation(fields: [claimId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
}

model CompanyVendor {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  category    String?  // SaaS, Utilities, Rent, Marketing, Operations, etc.
  website     String?
  wid         Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([name, wid])
}

model RecurringContract {
  id              String   @id @default(cuid())
  title           String
  vendor          String
  amount          Float
  currency        String   @default("USD")
  billingCycle    String   // "Monthly" | "Quarterly" | "Yearly"
  startDate       String
  nextRenewalDate String
  status          String   @default("Active") // "Active" | "Paused" | "Expired"
  wid             Int      @default(1)
  createdAt       DateTime @default(now())
}

